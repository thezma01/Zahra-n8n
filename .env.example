# Application
NODE_ENV=development
PORT=3000
APP_NAME=POS System
APP_URL=http://localhost:3000

# Database
DB_CLIENT=pg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=pos_db
DB_USER=postgres
DB_PASSWORD=secret
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# PIN Configuration
PIN_LENGTH=5
PIN_MAX_ATTEMPTS=5
PIN_LOCKOUT_MINUTES=15

# OTP Configuration
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3

# Email (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME=POS System
SMTP_FROM_EMAIL=noreply@possystem.com

# UI Theme
PRIMARY_COLOR=#16a34a
PRIMARY_HOVER=#15803d
LOGO_URL=/assets/logo.png
